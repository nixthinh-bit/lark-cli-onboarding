#!/bin/bash
# lark-cli-check-update — throttled (default 30-day) update check for @larksuite/cli.
#
# Usage:
#   lark-cli-check-update            # verbose: notify if a newer version exists
#   lark-cli-check-update --quiet    # hook/cron mode: same, but stays quiet unless there is news
#
# Behaviour:
#   - Runs at most once every LARK_CLI_UPDATE_INTERVAL_DAYS days (default 30). In
#     between it exits instantly with NO network call, so wiring it into a
#     SessionStart hook is cheap.
#   - When the interval elapses it compares the installed version against the npm
#     `latest`. If a newer one exists it NOTIFIES by default (prints the upgrade
#     command). Set LARK_CLI_AUTO_UPDATE=1 to install it automatically instead.
#   - The timestamp is written BEFORE the network check, so a slow/failed npm
#     lookup never causes it to retry every session.
#
# Exit code is always 0 — an update check must never block a session.

set -u

INTERVAL="${LARK_CLI_UPDATE_INTERVAL_DAYS:-30}"
STAMP="${HOME}/.lark-cli/.last-update-check"

QUIET=""
[ "${1:-}" = "--quiet" ] && QUIET=1

# --- make lark-cli / npm findable regardless of how they were installed --------
for d in \
  "$HOME/.npm-global/bin" \
  "$(npm config get prefix 2>/dev/null)/bin" \
  /opt/homebrew/bin \
  /usr/local/bin \
  "$HOME/.local/bin"; do
  case ":$PATH:" in *":$d:"*) ;; *) [ -d "$d" ] && PATH="$d:$PATH" ;; esac
done
export PATH

say()  { [ -z "$QUIET" ] && printf '\033[1;36m▶\033[0m %s\n' "$*"; }
ok()   { printf '\033[1;32m✓\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m!\033[0m %s\n' "$*"; }

now="$(date +%s)"
mkdir -p "$(dirname "$STAMP")"

# --- throttle: skip entirely if checked within INTERVAL days -------------------
if [ -f "$STAMP" ]; then
  last="$(cat "$STAMP" 2>/dev/null || echo 0)"
  case "$last" in ''|*[!0-9]*) last=0 ;; esac
  age=$(( now - last ))
  if [ "$age" -lt $(( INTERVAL * 86400 )) ]; then
    exit 0
  fi
fi

command -v lark-cli >/dev/null 2>&1 || exit 0
command -v npm      >/dev/null 2>&1 || exit 0

# record the attempt now, so a failed/slow lookup won't re-run next session
echo "$now" > "$STAMP"

say "Checking for a newer @larksuite/cli (runs ~once every ${INTERVAL} days) …"

local_v="$(lark-cli --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1)"
remote_v="$(npm view @larksuite/cli version 2>/dev/null)"

if [ -z "$local_v" ] || [ -z "$remote_v" ]; then exit 0; fi
if [ "$local_v" = "$remote_v" ]; then exit 0; fi

# only act when remote is strictly newer (sort -V puts the highest last)
newest="$(printf '%s\n%s\n' "$local_v" "$remote_v" | sort -V | tail -1)"
if [ "$newest" = "$local_v" ]; then exit 0; fi

if [ "${LARK_CLI_AUTO_UPDATE:-0}" = "1" ]; then
  if npm install -g @larksuite/cli@latest >/dev/null 2>&1; then
    ok "lark-cli auto-updated ${local_v} → ${remote_v}"
  else
    warn "lark-cli ${remote_v} is available but auto-update failed. Run: npm i -g @larksuite/cli@latest"
  fi
else
  warn "lark-cli ${local_v} installed; ${remote_v} is available. Update with: npm i -g @larksuite/cli@latest"
fi

exit 0
